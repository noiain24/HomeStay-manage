rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: bookings
    // Fields: ownerId, status, bookingDate, guestName, phone, roomType, checkIn, checkOut, amount, roomStatus, slip, note, source
    //
    // Collection: rooms
    // Fields: ownerId, id, name, description, amenities, price, status, imageUrl, capacity
    //
    // Collection: promos
    // Fields: ownerId, name, discount, startDate, endDate, status
    //
    // Collection: settings
    // Fields: ownerId, homestayName, homestaySuffix, heroSloganTop, heroDescription, contactPhone, contactEmail, contactLineId, contactFacebookUrl, contactAddress, bankName, bankAccountNo, bankAccountName, promptPayId, themePreset, fontStyle
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          // Check if user has admin role in users collection
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          // Fallback to hardcoded admin email
          request.auth.token.email == "koporikkung@gmail.com"
        );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /bookings/{bookingId} {
      // Allow reading if the user is an admin OR if they are the owner of the document
      // Note: For queries, this requires a where('ownerId', '==', request.auth.uid) filter
      allow read: if isAuthenticated() && (isAdmin() || (resource != null && resource.data.ownerId == request.auth.uid) || (resource == null));
      
      allow create: if isAuthenticated() && 
        request.resource.data.ownerId == request.auth.uid &&
        hasRequiredFields(['ownerId', 'guestName', 'roomType', 'checkIn', 'checkOut', 'amount']);
        
      allow update: if isAuthenticated() && 
        (isAdmin() || (resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == request.auth.uid));
        
      allow delete: if isAuthenticated() && (isAdmin() || resource.data.ownerId == request.auth.uid);
    }

    match /rooms/{roomId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && (isAdmin() || (resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == request.auth.uid));
      allow delete: if isAuthenticated() && (isAdmin() || resource.data.ownerId == request.auth.uid);
    }

    match /promos/{promoId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && (isAdmin() || (resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == request.auth.uid));
      allow delete: if isAuthenticated() && (isAdmin() || resource.data.ownerId == request.auth.uid);
    }

    match /settings/{settingsId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && (isAdmin() || (resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == request.auth.uid));
      allow delete: if isAuthenticated() && (isAdmin() || resource.data.ownerId == request.auth.uid);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
